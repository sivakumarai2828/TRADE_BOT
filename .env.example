# ══════════════════════════════════════════════════════════════════════════════
#  AI Trading Bot — environment configuration  (US Edition)
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── Exchange ──────────────────────────────────────────────────────────────────
#
#  US-LEGAL OPTIONS (Binance.com and Bybit are blocked in the US):
#
#  coinbase   ← RECOMMENDED — Coinbase Advanced Trade API
#               No testnet → use DRY_RUN=true (paper trading mode).
#               Get API keys: https://www.coinbase.com/settings/api
#               Permissions needed: View + Trade (Spot)
#
#  kraken     ← Good alternative. No testnet.
#               Get API keys: https://www.kraken.com/u/security/api
#               Permissions needed: Query + Create & Modify Orders
#
EXCHANGE_ID=coinbase

# No testnet available for US exchanges.
# Paper trading mode (DRY_RUN=true) is the safe substitute — it uses real
# market data but simulates all orders against a virtual $10,000 balance.
USE_TESTNET=false
DRY_RUN=true

# ── Exchange API keys ─────────────────────────────────────────────────────────
# Leave blank to run in paper trading mode (no keys required for market data).
# Fill in your real keys only when DRY_RUN=false.
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Trading ───────────────────────────────────────────────────────────────────
SYMBOL=BTC/USDT
TIMEFRAME=1m
CANDLE_LIMIT=100
POLLING_SECONDS=60

# ── Risk management ───────────────────────────────────────────────────────────
# Mandatory maximum is $50. config.py rejects larger values.
TRADE_SIZE_USDT=50
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.05

# Optional trailing stop (disabled by default)
USE_TRAILING_STOP=false
TRAILING_STOP_PCT=0.015

# ── API server (api.py / Flask) ───────────────────────────────────────────────
API_PORT=5000
FLASK_DEBUG=false
